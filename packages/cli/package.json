{
  "name": "n8n-lint",
  "version": "0.0.0",
  "description": "Validate n8n workflow JSON before it reaches production.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sherunscode/n8n-lint.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/sherunscode/n8n-lint/issues"
  },
  "homepage": "https://github.com/sherunscode/n8n-lint/tree/main/packages/cli#readme",
  "keywords": [
    "n8n",
    "workflow",
    "lint",
    "validation",
    "cli",
    "ci"
  ],
  "bin": {
    "n8n-lint": "dist/bin.js"
  },
  "main": "dist/bin.js",
  "types": "dist/bin.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@n8nproof/core": "0.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0"
  }
}
